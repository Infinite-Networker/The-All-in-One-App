# The All-in-One App — .gitignore
# Cherry Computer Ltd.

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
*.local

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ─── React Native ────────────────────────────────────────────────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
.expo/
dist/
buck-out/
build/
.buckd/
*.keystore
!debug.keystore

# iOS
ios/Pods/
ios/build/
ios/*.xcarchive
*.xcworkspace/xcuserdata/
!default.xcworkspace

# Android
android/.gradle/
android/local.properties
android/app/build/
android/*.iml

# ─── Backend ─────────────────────────────────────────────────────────────────
backend/node_modules/
backend/.env
backend/logs/
backend/*.log
backend/uploads/

# ─── Build Outputs ───────────────────────────────────────────────────────────
dist/
build/
out/
coverage/
.cache/

# ─── IDE & Editor ────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo
.DS_Store
Thumbs.db
*.vsix

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ─── Testing ─────────────────────────────────────────────────────────────────
coverage/
.jest-cache/
htmlcov/
*.cover
.tox/

# ─── Python (legacy, keeping for safety) ─────────────────────────────────────
__pycache__/
*.py[codz]
*.so
*.egg-info/
.venv
venv/

# ─── Misc ────────────────────────────────────────────────────────────────────
.abstra/
.ruff_cache/
.cursorignore
