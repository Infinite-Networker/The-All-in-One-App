# The All-in-One App — Environment Variables
# Cherry Computer Ltd.
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# NEVER share these credentials publicly.

# ─────────────────────────────────────────────────────────────────────────────
# PLATFORM OAUTH CREDENTIALS
# ─────────────────────────────────────────────────────────────────────────────

# Instagram (Meta Business Suite)
# https://developers.facebook.com/apps/
INSTAGRAM_CLIENT_ID=your_instagram_client_id_here
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret_here

# X / Twitter (Twitter Developer Portal)
# https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here

# Facebook (Meta Business Suite)
# https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# TikTok (TikTok for Developers)
# https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# LinkedIn (LinkedIn Developer Portal)
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# YouTube / Google (Google Cloud Console)
# https://console.cloud.google.com/
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND API
# ─────────────────────────────────────────────────────────────────────────────

API_BASE_URL=http://localhost:5000/api
WS_URL=ws://localhost:5000

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────────────────

# 32-character AES-256 encryption key for token storage
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_character_encryption_key_here

# JWT Secrets (for backend)
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_chars
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_different_from_above

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (Backend only)
# ─────────────────────────────────────────────────────────────────────────────

MONGODB_URI=mongodb://localhost:27017/allinoneapp
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# SERVER (Backend only)
# ─────────────────────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ─────────────────────────────────────────────────────────────────────────────
# The All-in-One App
# © 2026 Dr. Ahmad Mateen Ishanzai | Cherry Computer Ltd.
# ─────────────────────────────────────────────────────────────────────────────
